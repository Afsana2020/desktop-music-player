{
  "name": "cassette-player",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "npx vite",
    "dev:electron": "npx concurrently -k \"npm run dev\" \"npm run electron:start\"",
    "electron:start": "npx wait-on tcp:42138 && npx cross-env VITE_DEV_SERVER_URL=http://localhost:42138 npx electron .",
    "build": "npx vite build",
    "make-installer": "npm run build && npx electron-builder --win",
    "build:zip": "npm run build && npx electron-packager . AHMixtape --platform=win32 --arch=x64 --out=release --overwrite --asar",
    "lint": "npx eslint .",
    "preview": "npx vite preview"
  },
  "build": {
    "appId": "com.riptunes.mixtape",
    "productName": "A.H. Mixtape",
    "win": {
      "target": "zip"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.cjs"
    ]
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  }
}
